{
  "manifest_version": 3,
  "name": "Social Companion & YT Note-Taker",
  "version": "1.0.0",
  "description": "Premium companion for YouTube, X (Twitter), and Reddit. Take timestamped notes, extract transcripts/comments/recommendations with metadata, capture screenshots, and export to markdown/LLMs.",
  "permissions": [
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://*.twitter.com/*",
    "https://*.x.com/*",
    "https://*.reddit.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://*.twitter.com/*",
        "https://*.x.com/*",
        "https://*.reddit.com/*"
      ],
      "js": ["helpers.js", "content.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://*.youtube.com/*"
      ],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_title": "Social Companion"
  }
}
