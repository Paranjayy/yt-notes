{
  "manifest_version": 3,
  "name": "Social Companion & YT Note-Taker",
  "version": "1.3.0",
  "description": "Premium companion for YouTube, X (Twitter), Reddit, and Cambridge Dictionary. Take notes, extract transcripts, scrape word lists, and export to markdown/JSON/CSV.",
  "permissions": [
    "storage",
    "clipboardWrite",
    "clipboardRead",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://*.twitter.com/*",
    "https://*.x.com/*",
    "https://*.reddit.com/*",
    "https://*.dictionary.cambridge.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://*.twitter.com/*",
        "https://*.x.com/*",
        "https://*.reddit.com/*"
      ],
      "js": ["helpers.js", "content.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://*.dictionary.cambridge.org/plus/wordlist",
        "https://*.dictionary.cambridge.org/plus/wordlist?*",
        "https://*.dictionary.cambridge.org/plus/wordlist/*"
      ],
      "js": ["dictionary.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Social Companion — Open Dashboard",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["dashboard.html", "dashboard.js", "vocab-trainer.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
